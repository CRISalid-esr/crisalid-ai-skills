# --- Keycloak (required for authenticated toolset) ---
KEYCLOAK_ISSUER=https://<keycloak-host>/realms/<realm>
KEYCLOAK_CLIENT_ID=example-mcp-client
KEYCLOAK_CLIENT_SECRET=
# Set to false if Keycloak uses a self-signed certificate (local dev only)
KEYCLOAK_SSL_VERIFY=true

# --- OpenAI-compatible LLM (vllm or other) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=http://<vllm-host>:<port>/v1
OPENAI_MODEL=<model-name>